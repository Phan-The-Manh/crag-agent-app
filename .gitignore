########################################
# Python / FastAPI project .gitignore
########################################

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
.env.*/

# Environment and secrets
.env
*.env
*.env.local
*.env.*.local

# VS Code / IDE
.vscode/
.idea/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# Coverage / test reports
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.pytest_cache/
nosetests.xml

# MyPy / type checker
.mypy_cache/
.dmypy.json
dmypy.json

# Packaging
build/
dist/
*.egg-info/
*.egg

# Local data / vector store indices
data/
vector_store/

